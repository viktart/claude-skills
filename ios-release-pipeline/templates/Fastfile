default_platform(:ios)

SCHEME = "<Scheme>"
APP_TARGET = "<AppTarget>"  # app target name — often equals the scheme, but not always
XCODEPROJ = "<XcodeprojName>.xcodeproj"  # often named after the scheme, but not always — discovered at scaffold time
UNIT_TEST_TARGET = "<UnitTestTarget>"
USES_XCODEGEN = <true_or_false>  # true if project.yml exists
SIMULATOR_NAME = "<SimulatorName>"  # asked of the user at scaffold time — never assumed

# Build-time secrets (all read from fastlane/.env locally, or CI env). Signing uses Apple's
# cloud-managed certificates via this same API key — there is no local certificate, keychain
# import, or certs repo anywhere in the pipeline.
REQUIRED_SECRETS = %w[ASC_KEY_ID ASC_ISSUER_ID ASC_KEY_CONTENT]

platform :ios do
  before_all do
    setup_ci if is_ci
  end

  desc "Full release: bump version, run tests, build, upload to TestFlight, push"
  lane :release do |options|
    bump_type = options[:bump_type] || "patch"
    version = bump_app_version(bump_type: bump_type)
    run_unit_tests
    build_and_upload
    commit_tag_and_push(version: version)
  end

  desc "Quick release (no tests) — meant for the manual GitHub Action"
  lane :release_quick do |options|
    bump_type = options[:bump_type] || "patch"
    version = bump_app_version(bump_type: bump_type)
    build_and_upload
    commit_tag_and_push(version: version)
  end

  desc "Collect the App Store Connect secrets, push them to GitHub, preflight CI permissions (run locally once)"
  lane :setup_secrets do
    ensure_secrets_collected
    push_secrets_to_github
    check_workflow_permissions
  end

  # ---- private helpers ----

  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )
  end

  # xcodebuild's -authenticationKeyPath needs the raw .p8 on disk at an absolute path;
  # ASC_KEY_CONTENT carries it base64-encoded. Written outside the repo so it can never be
  # committed by accident.
  private_lane :asc_key_file do
    require "base64"
    require "tmpdir"
    path = File.join(Dir.tmpdir, "asc_#{ENV['ASC_KEY_ID']}.p8")
    File.write(path, Base64.decode64(ENV["ASC_KEY_CONTENT"]))
    File.chmod(0o600, path)
    path
  end

  # Interactively collects any missing secrets by launching fastlane/scripts/collect-secrets.sh —
  # only reachable from setup_secrets, which is always run directly by a human in their own
  # terminal, so the script's `read` prompts have a real TTY. Uses plain `system`, not the `sh`
  # action, because `sh` pipes output for logging and can break interactive stdin — `system`
  # inherits the parent process's TTY untouched.
  private_lane :ensure_secrets_collected do
    missing = REQUIRED_SECRETS.select { |k| ENV[k].to_s.empty? }
    next if missing.empty?

    UI.important("Missing #{missing.join(', ')} — running scripts/collect-secrets.sh to collect them.")
    script = File.expand_path("scripts/collect-secrets.sh", __dir__)
    UI.user_error!("collect-secrets.sh failed or was cancelled") unless system(script)

    require "dotenv"
    Dotenv.overload(File.expand_path(".env", __dir__))  # child process wrote .env; reload into this process
  end

  # Fails fast with a clear message instead of letting the build hit a half-configured setup.
  # Secrets present in ENV (from .env locally, or CI env) is the reliable "setup_secrets has run" signal.
  private_lane :ensure_secrets_ready do
    missing = REQUIRED_SECRETS.select { |k| ENV[k].to_s.empty? }
    return if missing.empty?

    UI.user_error!("Missing #{missing.join(', ')} — the App Store Connect key isn't set up. Run `bundle exec fastlane setup_secrets` first.")
  end

  private_lane :push_secrets_to_github do
    script = File.expand_path("scripts/set-github-secrets.sh", __dir__)
    UI.important("Pushing secrets to GitHub repo secrets...")
    UI.user_error!("Failed to push secrets to GitHub — run fastlane/scripts/set-github-secrets.sh manually.") unless system(script)
  end

  private_lane :check_workflow_permissions do
    script = File.expand_path("scripts/check-workflow-permissions.sh", __dir__)
    system(script)  # best-effort warning only — never fails the lane over it
  end

  private_lane :bump_app_version do |options|
    bump_type = options[:bump_type] || "patch"

    if USES_XCODEGEN
      yml_path = "project.yml"
      content = File.read(yml_path)
      current = content[/MARKETING_VERSION:\s*"?([\d.]+)"?/, 1]
      UI.user_error!("MARKETING_VERSION not found in #{yml_path}") unless current

      major, minor, patch = current.split(".").map(&:to_i)
      case bump_type
      when "major" then major += 1; minor = 0; patch = 0
      when "minor" then minor += 1; patch = 0
      else patch += 1
      end
      new_version = "#{major}.#{minor}.#{patch}"

      File.write(yml_path, content.sub(/MARKETING_VERSION:\s*"?[\d.]+"?/, "MARKETING_VERSION: #{new_version}"))
      sh("xcodegen generate")
      new_version
    else
      increment_version_number(bump_type: bump_type, xcodeproj: XCODEPROJ)
      get_version_number(xcodeproj: XCODEPROJ, target: APP_TARGET)
    end
  end

  private_lane :run_unit_tests do
    run_tests(
      scheme: SCHEME,
      only_testing: [UNIT_TEST_TARGET],
      devices: [SIMULATOR_NAME]
    )
  end

  private_lane :build_and_upload do
    ensure_secrets_ready

    api_key = asc_api_key

    latest = latest_testflight_build_number(api_key: api_key) rescue 0
    increment_build_number(xcodeproj: XCODEPROJ, build_number: latest + 1)

    # Cloud signing: xcodebuild authenticates to Apple with the API key and Apple signs with a
    # cloud-managed distribution certificate (created automatically on first use). The auth flags
    # must be on BOTH the archive step (xcargs) and the export step (export_xcargs) — export
    # re-signs and needs them just as much.
    auth_args = "-allowProvisioningUpdates" \
                " -authenticationKeyPath #{asc_key_file}" \
                " -authenticationKeyID #{ENV['ASC_KEY_ID']}" \
                " -authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']}"

    build_app(
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs: auth_args,
      export_xcargs: auth_args,
      export_options: { signingStyle: "automatic" }
    )

    upload_to_testflight(api_key: api_key, skip_waiting_for_build_processing: true)
  end

  private_lane :commit_tag_and_push do |options|
    version = options[:version]

    # xcodegen projects often gitignore the .xcodeproj — commit only what git actually tracks.
    candidates = USES_XCODEGEN ? ["project.yml", "#{XCODEPROJ}/project.pbxproj"] : ["#{XCODEPROJ}/project.pbxproj"]
    paths = candidates.select { |p| system("git", "ls-files", "--error-unmatch", p, out: File::NULL, err: File::NULL) }
    UI.user_error!("None of #{candidates.join(', ')} are tracked by git — nothing to commit for the version bump") if paths.empty?

    if is_ci
      sh("git config user.name 'github-actions[bot]'")
      sh("git config user.email 'github-actions[bot]@users.noreply.github.com'")
    end

    git_add(path: paths)
    git_commit(path: paths, message: "Bump version to #{version}")
    add_git_tag(tag: "v#{version}")
    push_to_git_remote(tags: true)
  end
end
